# AdOff - Environment Variables Example
# Copia questo file in .env e inserisci le tue credenziali reali

# ===================================================================
# CLOUDFLARE API TOKEN
# ===================================================================
# Necessario per:
# - wrangler deploy (Worker & Pages)
# - wrangler secret put (per configurare secrets)
# - wrangler kv:* (operazioni KV)
#
# Come creare il token:
# 1. Vai su: https://developers.cloudflare.com/fundamentals/api/get-started/create-token/
# 2. Crea token con permessi:
#    - Account > Cloudflare Pages > Edit
#    - Account > Cloudflare Pages > Deploy
#    - Account > Workers Scripts > Edit
#    - Account > Workers Scripts > Deploy
#    - Account > Workers KV Storage > Edit
# 3. Copia il token qui sotto

CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# ===================================================================
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# ===================================================================
# SEGRETI WRANGLER (NON metterli qui - usare wrangler secret put)
# ===================================================================
# Questi segreti devono essere configurati con:
# wrangler secret put ADOFF_SECRET
# wrangler secret put ADMIN_TOKEN
# wrangler secret put STRIPE_WEBHOOK_SECRET
#
# NON inserire i segreti reali in questo file!

# ADOFF_SECRET=     # Generato con: python -c "import secrets; print(secrets.token_hex(32))"
# ADMIN_TOKEN=      # Token per accedere al pannello admin
# STRIPE_WEBHOOK_SECRET=  # Secret per webhook Stripe

# ===================================================================
# CONFIGURAZIONE PROGETTO
# ===================================================================
# Project name per Cloudflare Pages
PAGES_PROJECT_NAME=adoff-site

# Worker name
WORKER_NAME=adoff-license-api

# ===================================================================
# ALTRO
# ===================================================================
# Node environment (opzionale)
NODE_ENV=production

# ===================================================================
# ISTRUZIONI
# ===================================================================
# 1. Copia questo file: cp .env.example .env
# 2. Inserisci le tue credenziali reali
# 3. Carica le variabili: source .env (oppure riavvia il terminale)
# 4. Verifica: echo $CLOUDFLARE_API_TOKEN
# 5. Deploy: wrangler deploy (per Worker)
# 6. Deploy: wrangler pages deploy site --project-name=adoff-site (per Pages)

# ===================================================================
# SICUREZZA
# ===================================================================
# ⚠️  MAI commitare il file .env con credenziali reali!
# ⚠️  .env è già in .gitignore (verifica che lo sia)
# ✅ .env.example è SICURO da commitare (solo esempi)
