.env

# Secrets — never commit
.secrets/
**/.secrets/
*.env
!*.env.example
*.kdbx

# PII archive — never commit
sviluppo/.archive-pii/

# Build artifacts (sviluppo/ + site/ download ZIP — generate at deploy)
sviluppo/build-chrome/
sviluppo/build-firefox/
sviluppo/build-safari/
sviluppo/adoff-*.zip
site/adoff-*.zip
web-ext-artifacts/

# Graphify AST output (generated locally)
graphify-out/
app/graphify-out/
app/src/graphify-out/
sviluppo/license-system/graphify-out/

# Node modules
node_modules

# Flutter / Dart (Android)
AdOff/.dart_tool/
AdOff/.flutter-plugins*
AdOff/pubspec.lock
AdOff/build/
AdOff/android/.gradle/
AdOff/android/gradle/
AdOff/android/app/build/
AdOff/android/app/src/debug/
AdOff/android/app/src/profile/
AdOff/test/
AdOff/.idea/
AdOff/*.iml
AdOff/.gitignore

# Python venv + pycache
sviluppo/.venv/
sviluppo/seo-tools/.venv/
**/__pycache__/
**/.pyc

# Logs (generated at runtime)
sviluppo/logs/*.log
sviluppo/seo-tools/.state/
sviluppo/reviews/package-lock.json

# SEO/ML state (generated by agents)
sviluppo/seo-tools/sessioni/
sviluppo/ml-cron/

# Admin UI (separate project)
sviluppo/admin-ui/

# Media queue (generated at runtime)
sviluppo/media-queue/

# Polar POC (test, not production)
sviluppo/license-system/polar-poc/

# Clone monitor state (local)
sviluppo/.clone-monitor-state.json
sviluppo/canaries.json

# Embedded git repos (not submodules — owned by other projects)
sviluppo/github-repo/
sviluppo/marketing/video-engine/
