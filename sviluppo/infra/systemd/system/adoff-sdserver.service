[Unit]
Description=AdOff SD Server (Flux.1 schnell text-to-image)
After=network.target

[Service]
Type=simple
User=mrxxx
WorkingDirectory=/home/mrxxx/sdcpp/models
ExecStart=/usr/bin/nice -n 10 /home/mrxxx/sdcpp/stable-diffusion.cpp/build/bin/sd-server --diffusion-model flux1-schnell-Q4_K_S.gguf --vae ae.safetensors --clip_l clip_l.safetensors --t5xxl t5xxl_q4.gguf --listen-ip 0.0.0.0 --listen-port 7860
Restart=always
RestartSec=15
MemoryMax=40G

[Install]
WantedBy=multi-user.target
