[Unit]
Description=AdOff â€” Triage automatico ticket di supporto (Claude: baseâ†’risposta, complessiâ†’Telegram)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=mrxxx
WorkingDirectory=/home/mrxxx/adoff
# Gate auto-invio email ai clienti: 0 = PROPOSE (bozze su Telegram), 1 = AUTO (risponde+chiude).
# I rimborsi/fatturazione/legale restano SEMPRE gestione umana, anche con 1.
