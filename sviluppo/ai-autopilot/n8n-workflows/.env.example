# W41 Learning Loop Engine — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)

# ============================================================================
# PostgreSQL Database Configuration
# ============================================================================

# Host: PostgreSQL server address
ADOFF_PG_HOST=postgres.leobox.internal

# Port: PostgreSQL server port
ADOFF_PG_PORT=5432

# Database: Database name
ADOFF_PG_DATABASE=adoff_autopilot

# User: Database user (should have write permissions)
ADOFF_PG_USER=adoff_writer

# Password: Database password (from 1password or secure vault)
ADOFF_PG_PASSWORD=

# SSL: Use SSL for connection (true/false)
# For internal networks, set to false
ADOFF_PG_SSL=false

# ============================================================================
# Telegram Configuration (for daily reports)
# ============================================================================

# Bot Token: From @BotFather on Telegram
# Format: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_TOKEN=

# Admin Chat ID: Your numeric chat ID (from @userinfobot)
# Format: 123456789 (NOT @username)
TELEGRAM_CHAT_ID_ADMIN=

# Operations Chat ID: For alerts/errors (optional)
TELEGRAM_CHAT_ID_OPS=

# ============================================================================
# n8n Configuration
# ============================================================================

# Webhook Base URL: n8n server URL for webhook triggers
# Used for manual W41 triggers
N8N_WEBHOOK_URL=http://localhost:5678/webhook/learning-run

# Webhook Secret: HMAC secret for webhook validation (W29 integration)
N8N_WEBHOOK_SECRET=

# n8n API Key: For inter-workflow communication (if needed)
N8N_API_KEY=

# ============================================================================
# Development Settings
# ============================================================================

# Environment: development | staging | production
NODE_ENV=production

# Debug: Enable verbose logging
DEBUG=false

# Test Mode: Insert test data and skip remote calls
TEST_MODE=false

# ============================================================================
# Notes
# ============================================================================

# 1. PostgreSQL: Get password from 1password (saved at deployment)
# 2. Telegram Bot Token: Create bot via @BotFather, copy token
# 3. Telegram Chat ID: Forward a message from yourself to @userinfobot, get numeric ID
# 4. n8n Webhook Secret: Use `openssl rand -hex 32` to generate
# 5. After filling values, set in n8n Settings → Environment Variables
# 6. Test connection: `psql -h $ADOFF_PG_HOST -U $ADOFF_PG_USER -d $ADOFF_PG_DATABASE -c "SELECT 1"`
