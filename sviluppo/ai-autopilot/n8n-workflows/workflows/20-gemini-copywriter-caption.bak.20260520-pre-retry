      "parameters": {
        "language": "javaScript",
        "jsCode": "\nfunction normalizeForGuard(s) {\n  if (!s) return '';\n  return String(s)\n    .normalize('NFD').replace(/[̀-ͯ]/g, '')\n    .toLowerCase()\n    .replace(/[·•​-‍﻿⁠]/g, '')\n    .replace(/\\s+/g, ' ');\n}\nfunction brandGuardCheck(rawText) {\n  const t = normalizeForGuard(rawText);\n  const BRANDS = ['youtube','you tube','y-tube','y tube','google','g00gle','gооgle','facebook','face book','instagram','insta gram','tiktok','tik tok','tik-tok','twitter','\\bx\\b','amazon','reddit','twitch','github','linkedin','chrome','firefox','safari','microsoft edge','opera'];\n  for (const b of BRANDS) {\n    const rx = new RegExp(b.replace(/\\\\b/g,'(?:^|[^\\\\p{L}\\\\p{N}])').replace(/\\\\s+/g,'\\\\s*'),'iu');\n    if (rx.test(t)) return { ok:false, hit:b };\n  }\n  const SIZE = /149[\\s\\-_]*k(?:ilo)?b(?:yte)?s?/iu;\n  if (SIZE.test(t)) return { ok:false, hit:'149kb' };\n  const BANNED_TERMS = /\\b(15[\\s\\-]?day|trial|paid plan|subscription|sottoscrizione|abbonamento|pricing|euro\\/mese)/iu;\n  if (BANNED_TERMS.test(t)) return { ok:false, hit:'pricing_term' };\n  return { ok:true };\n}\n\nconst meta = $('Build Gemini prompt').item.json;\nconst resp = $json;\nlet text = '';\ntry { text = resp.candidates?.[0]?.content?.parts?.[0]?.text || ''; } catch(e){}\nlet parsed = null;\ntry { parsed = JSON.parse(text); } catch(e) {\n  const m = text.match(/\\{[\\s\\S]*\\}/);\n  if (m) { try { parsed = JSON.parse(m[0]); } catch(e2){} }\n}\nif (!parsed || !parsed.caption) return [{ json: { ...meta, ok:false, reason:'gemini_no_valid_json', raw:text.slice(0,300) } }];\nconst caption = String(parsed.caption || '').trim();\nconst hashtags = Array.isArray(parsed.hashtags) ? parsed.hashtags.map(h=>String(h).trim()).filter(Boolean) : [];\nconst cta = String(parsed.cta || '').trim();\n// F013: schema validation\nif (!Array.isArray(parsed.hashtags)) return [{ json: { ...meta, ok:false, reason:'hashtags_not_array' } }];\nif (caption.length < 25 || caption.length > 2200) return [{ json: { ...meta, ok:false, reason:'caption_length_oor', len:caption.length } }];\nif (hashtags.length < 2 || hashtags.length > 15) return [{ json: { ...meta, ok:false, reason:'hashtags_count_oor', n:hashtags.length } }];\nconst guard = brandGuardCheck(caption + ' ' + hashtags.join(' ') + ' ' + cta);\nif (!guard.ok) return [{ json: { ...meta, ok:false, reason:'brand_guard_'+guard.hit, preview:caption.slice(0,200) } }];\nreturn [{ json: { ...meta, ok:true, caption, hashtags, cta, body_json: JSON.stringify({caption,hashtags,cta}), model:'gemini-2.5-flash', tokens_in: resp.usageMetadata?.promptTokenCount||0, tokens_out: resp.usageMetadata?.candidatesTokenCount||0 } }];"
