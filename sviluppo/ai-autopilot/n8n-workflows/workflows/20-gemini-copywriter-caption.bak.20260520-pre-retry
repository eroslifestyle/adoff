        "language": "javaScript",
        "jsCode": "// F004 cost-cap + F003 input sanitize\nconst input = items[0]?.json?.body || items[0]?.json || {};\nconst MAX_LANGS = 15, MAX_PLATFORMS = 5, MAX_CONCEPT_LEN = 1500;\nconst concept0 = String(input.concept || 'AdOff blocca la pubblicità invasiva: video puliti, navigazione veloce, privacy.').slice(0, MAX_CONCEPT_LEN);\nconst concept = concept0.replace(/[\\u0000-\\u001f\\u007f]/g,'');\nlet langs = Array.isArray(input.langs) && input.langs.length ? input.langs : ['it','en','de','fr','es'];\nlet platforms = Array.isArray(input.platforms) && input.platforms.length ? input.platforms : ['instagram','facebook','tiktok'];\nlangs = langs.slice(0, MAX_LANGS).filter(l=>/^[a-z]{2,5}$/i.test(l));\nplatforms = platforms.slice(0, MAX_PLATFORMS).filter(p=>/^[a-z0-9_-]{2,30}$/i.test(p));\nif (langs.length === 0 || platforms.length === 0) throw new Error('Invalid langs or platforms after sanitize');\nconst tone = String(input.tone || 'energica, brillante, diretta (stile Ava Multilingual)').slice(0, 300);\nconst videoMasterId = input.video_master_id ? String(input.video_master_id).slice(0, 100) : null;\nconst out = [];\nfor (const lang of langs) {\n  for (const platform of platforms) {\n    out.push({ json: { concept, lang, platform, tone, video_master_id: videoMasterId } });\n  }\n}\nreturn out;"
