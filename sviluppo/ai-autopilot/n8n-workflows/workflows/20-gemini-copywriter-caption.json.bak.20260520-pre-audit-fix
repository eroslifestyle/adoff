      "id": "node-003-set-defaults",
      "name": "Set defaults",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 300],
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Set defaults + esplodi (lang × platform) → 1 item per (lang, platform)\nconst input = items[0]?.json?.body || items[0]?.json || {};\nconst concept = input.concept || 'AdOff blocca la pubblicità invasiva: video puliti, navigazione veloce, privacy.';\nconst langs = Array.isArray(input.langs) && input.langs.length ? input.langs : ['it','en','de','fr','es'];\nconst platforms = Array.isArray(input.platforms) && input.platforms.length ? input.platforms : ['instagram','facebook','tiktok'];\nconst tone = input.tone || 'energica, brillante, diretta (stile Ava Multilingual)';\nconst videoMasterId = input.video_master_id || null;\nconst out = [];\nfor (const lang of langs) {\n  for (const platform of platforms) {\n    out.push({ json: { concept, lang, platform, tone, video_master_id: videoMasterId } });\n  }\n}\nreturn out;"
      }
    },
    {
      "id": "node-004-split-batches",
      "name": "Throttle (1 req)",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [720, 300],
      "parameters": {
        "batchSize": 1,
        "options": {}
      }
