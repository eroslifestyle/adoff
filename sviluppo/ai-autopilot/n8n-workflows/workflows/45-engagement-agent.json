        "query": "SELECT COUNT(*) as total, SUM(CASE WHEN status='sent' THEN 1 ELSE 0 END) as sent, SUM(CASE WHEN status='escalated' THEN 1 ELSE 0 END) as escalated, SUM(CASE WHEN status='ignored' THEN 1 ELSE 0 END) as ignored FROM engagement_inbox WHERE DATE(created_at) = CURRENT_DATE;"
      },
