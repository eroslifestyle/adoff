    {
      "id": "node-010-merge-all-comments",
      "name": "Merge all platforms",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1680,
        200
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Collect comments from all platforms\nconst allComments = [];\nconst timestamp = new Date().toISOString();\n\n// Twitter response\nconst twitterResp = $('Phase A: Twitter (discover)').json;\nif (twitterResp?.data && Array.isArray(twitterResp.data)) {\n  twitterResp.data.forEach(tweet => {\n    allComments.push({\n      platform: 'twitter',\n      comment_id: tweet.id,\n      author_handle: tweet.author_id,\n      content: tweet.text,\n      created_at: tweet.created_at || timestamp,\n      source_post_id: $env.TWITTER_POST_ID\n    });\n  });\n}\n\n// Reddit response\nconst redditResp = $('Phase A: Reddit (discover)').json;\nif (redditResp?.data?.children && Array.isArray(redditResp.data.children)) {\n  redditResp.data.children.forEach(child => {\n    const comment = child.data;\n    if (comment && comment.body) {\n      allComments.push({\n        platform: 'reddit',\n        comment_id: comment.id,\n        author_handle: comment.author,\n        content: comment.body,\n        created_at: new Date(comment.created_utc * 1000).toISOString(),\n        source_post_id: $env.REDDIT_POST_ID\n      });\n    }\n  });\n}\n\n// Mastodon response\nconst mastodonResp = $('Phase A: Mastodon (discover)').json;\nif (mastodonResp?.descendants && Array.isArray(mastodonResp.descendants)) {\n  mastodonResp.descendants.forEach(status => {\n    allComments.push({\n      platform: 'mastodon',\n      comment_id: status.id,\n      author_handle: status.account?.acct,\n      content: status.content,\n      created_at: status.created_at,\n      source_post_id: $env.MASTODON_POST_ID\n    });\n  });\n}\n\nreturn allComments.map(c => ({ json: c }));"
      }
    },
