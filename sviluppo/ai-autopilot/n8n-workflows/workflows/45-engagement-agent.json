    {
      "id": "node-014-phase-c-build-gemini-prompt",
      "name": "Phase C: Build Gemini prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2640,
        100
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const { platform, author_handle, content, source_post_id } = $json;\nconst captionPreview = `[Post su ${platform}]`; // Ideally from DB\nconst prompt = `Sei community manager AdOff (estensione anti-pubblicità). Analizza questo commento:\\nPLATFORM: ${platform}\\nCOMMENTO: <USER_COMMENT>${content}</USER_COMMENT>\\nCONTESSTO POST: \"${captionPreview}\"\\n\\nRestituisci JSON:\\n{\\n  \"intent\": \"question|praise|complaint|spam|press|legal|other\",\\n  \"sentiment\": 0.0-1.0,\\n  \"priority\": 1-10 (10=urgentissimo),\\n  \"suggested_reply\": \"risposta brand-safe in ita max 280 char, energica/brillante, no brand famosi, no '149 KB', usa sinonimi\",\\n  \"should_auto_reply\": true|false,\\n  \"escalation_reason\": null o stringa,\\n  \"tone_check_ok\": true|false\\n}\\n\\nREGOLE:\\n- se intent='spam' → should_auto_reply=false\\n- se intent IN ('complaint','legal','press') → should_auto_reply=false, escalation_reason=\"manuale\"\\n- se sentiment < 0.4 → should_auto_reply=false\\n- se intent='question' e sentiment > 0.5 → reply utile breve\\n- se intent='praise' → reply breve grazie con CTA soft`;\n\nreturn [{ json: { ...items[0].json, prompt, lang: 'it', model: 'gemini-2.5-flash' } }];"
      }
    },
    {
      "id": "node-015-gemini-classify",
      "name": "Gemini 2.5 Flash classify",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2880,
        100
      ],
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ contents:[{role:'user',parts:[{text:$json.prompt}]}], generationConfig:{ temperature:0.7, topP:0.9, maxOutputTokens:500, responseMimeType:'application/json', thinkingConfig:{thinkingBudget:0} }, safetySettings:[ {category:'HARM_CATEGORY_HARASSMENT',threshold:'BLOCK_NONE'}, {category:'HARM_CATEGORY_HATE_SPEECH',threshold:'BLOCK_NONE'}, {category:'HARM_CATEGORY_SEXUALLY_EXPLICIT',threshold:'BLOCK_NONE'}, {category:'HARM_CATEGORY_DANGEROUS_CONTENT',threshold:'BLOCK_NONE'} ] }) }}",
        "options": {
          "timeout": 30000,
          "response": {
            "neverError": true,
            "fullResponse": false
          },
          "retry": {
            "enabled": true,
            "maxTries": 3,
            "waitBetweenTries": 2000
          }
        }
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "adoff-gemini-credential-2026",
          "name": "AdOff Gemini API (ServerN8N free/tier1)"
        }
      }
    },
    {
      "id": "node-016-parse-gemini",
      "name": "Parse Gemini response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3120,
        100
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const meta = $('Phase C: Build Gemini prompt').json;\nconst resp = $json;\nlet text = '';\ntry { text = resp.candidates?.[0]?.content?.parts?.[0]?.text || ''; } catch(e){}\nlet parsed = null;\ntry { parsed = JSON.parse(text); } catch(e) {\n  const m = text.match(/\\{[\\s\\S]*\\}/);\n  if (m) { try { parsed = JSON.parse(m[0]); } catch(e2){} }\n}\n\nif (!parsed || !parsed.intent) {\n  return [{ json: { ...meta, ok: false, reason: 'gemini_parse_fail', raw: text.slice(0,200) } }];\n}\n\nconst intent = String(parsed.intent || '').toLowerCase();\nconst sentiment = Number(parsed.sentiment) || 0.5;\nconst priority = Number(parsed.priority) || 5;\nconst suggested_reply = String(parsed.suggested_reply || 'Grazie per il feedback!').slice(0, 280);\nconst escalation_reason = parsed.escalation_reason || null;\nlet should_auto_reply = Boolean(parsed.should_auto_reply);\n\n// Apply rules\nif (intent === 'spam') should_auto_reply = false;\nif (['complaint', 'legal', 'press'].includes(intent)) {\n  should_auto_reply = false;\n  if (!escalation_reason) { return [{ json: { ...meta, escalation_reason: 'manuale' } }]; }\n}\nif (sentiment < 0.4) should_auto_reply = false;\n\nreturn [{ json: { ...meta, intent, sentiment, priority, suggested_reply, should_auto_reply, escalation_reason, ok: true } }];"
      }
    },
    {
