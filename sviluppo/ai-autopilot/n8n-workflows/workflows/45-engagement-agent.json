    {
      "id": "node-019-brand-guard-before-reply",
      "name": "Brand-guard (before POST)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3840,
        50
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "function normalizeForGuard(s) {\n  if (!s) return '';\n  return String(s)\n    .normalize('NFD').replace(/[̀-ͯ]/g, '')\n    .toLowerCase()\n    .replace(/[·•​-‍﻿⁠]/g, '')\n    .replace(/\\s+/g, ' ');\n}\nfunction brandGuardCheck(rawText) {\n  const t = normalizeForGuard(rawText);\n  const BRANDS = ['youtube','google','facebook','instagram','tiktok','twitter','amazon','reddit','twitch','github','linkedin'];\n  for (const b of BRANDS) {\n    if (t.includes(b)) return { ok: false, hit: b };\n  }\n  if (/149[\\s\\-_]*k(?:ilo)?b(?:yte)?s?/iu.test(t)) return { ok: false, hit: '149kb' };\n  return { ok: true };\n}\n\nconst guard = brandGuardCheck($json.suggested_reply);\nif (!guard.ok) {\n  return [{ json: { ...$json, brand_guard_ok: false, guard_reason: guard.hit, action: 'escalate' } }];\n}\nreturn [{ json: { ...$json, brand_guard_ok: true } }];"
      }
    },
