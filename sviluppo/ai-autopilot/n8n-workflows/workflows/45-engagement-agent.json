    {
      "id": "node-003-hmac-validator",
      "name": "HMAC Auth (W29)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        300
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Reusable HMAC-SHA256 validator from W29\nconst crypto = require('crypto');\nconst secret = process.env.WEBHOOK_HMAC_SECRET;\n\nconst isSchedule = $node['Schedule (15 min)'] !== undefined && $json.source === undefined;\nif (isSchedule) {\n  return [{ json: { auth_ok: true, source: 'schedule', route: 'schedule' } }];\n}\n\n// Webhook validation\nif (!secret) {\n  return [{ json: { auth_ok: false, reason: 'WEBHOOK_HMAC_SECRET not configured' } }];\n}\n\nconst signature = $headers?.['x-adoff-signature'];\nif (!signature) {\n  return [{ json: { auth_ok: false, reason: 'missing_signature_header' } }];\n}\n\nconst bodyRaw = $body || JSON.stringify($json);\nconst expectedHmac = crypto\n  .createHmac('sha256', Buffer.from(secret, 'hex'))\n  .update(bodyRaw, 'utf8')\n  .digest('hex');\n\ntry {\n  crypto.timingSafeEqual(\n    Buffer.from(signature, 'hex'),\n    Buffer.from(expectedHmac, 'hex')\n  );\n  return [{ json: { auth_ok: true, source: 'webhook', route: 'engagement-now', payload: $json } }];\n} catch (err) {\n  return [{ json: { auth_ok: false, reason: 'invalid_signature' } }];\n}"
      }
    },
