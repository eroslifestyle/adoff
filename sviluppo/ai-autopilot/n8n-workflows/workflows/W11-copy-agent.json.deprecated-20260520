    {
      "id": "parse",
      "name": "Parse output",
      "type": "n8n-nodes-base.code",
      "position": [900, 400],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const llmResp = $input.first().json;\nconst meta = $node['Prepare prompt'].json.request_meta;\n\nconst raw = (llmResp.response || '').trim();\n\n// Estrai varianti se numerate (1. ... 2. ... 3. ...)\nlet variants = [];\nconst numberedRegex = /^\\s*(\\d+)\\.\\s+/gm;\nconst matches = [...raw.matchAll(numberedRegex)];\nif (matches.length >= 2) {\n  for (let i = 0; i < matches.length; i++) {\n    const start = matches[i].index + matches[i][0].length;\n    const end = i + 1 < matches.length ? matches[i + 1].index : raw.length;\n    const text = raw.slice(start, end).trim();\n    if (text) variants.push(text);\n  }\n} else {\n  variants = [raw];\n}\n\n// Estrai hashtag + emoji + char count per ogni variante\nconst stats = variants.map(v => {\n  const hashtags = (v.match(/#\\w+/g) || []);\n  const emojis = (v.match(/[\\u{1F300}-\\u{1FAFF}\\u{2600}-\\u{27BF}]/gu) || []);\n  return {\n    text: v,\n    char_count: v.length,\n    word_count: v.split(/\\s+/).length,\n    hashtag_count: hashtags.length,\n    hashtags: hashtags,\n    emoji_count: emojis.length,\n    emojis: emojis\n  };\n});\n\nreturn [{\n  json: {\n    success: true,\n    request: meta,\n    variants: stats,\n    primary_copy: stats[0]?.text || '',\n    eval_count: llmResp.eval_count,\n    eval_duration_ms: Math.round((llmResp.eval_duration || 0) / 1e6),\n    tok_per_sec: llmResp.eval_count && llmResp.eval_duration ? Math.round(llmResp.eval_count / (llmResp.eval_duration / 1e9) * 10) / 10 : null,\n    raw_response: raw\n  }\n}];"
      },
