      "parameters": {
        "language": "javaScript",
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst platform = body.platform || 'twitter';\nconst persona = body.persona || 'tech_geek';\nconst framework = body.framework || 'PAS';\nconst language = body.language || 'en';\nconst topic = body.topic || '';\nconst context = body.context || '';\nconst variants = Math.max(1, Math.min(parseInt(body.variants || 1), 5));\n\nconst temp_map = { hook: 1.0, body: 0.7, cta: 0.4, validation: 0.2 };\nconst temperature = body.temperature || 0.85;\n\nconst inputJson = { platform, persona, framework, language, topic, context, variants };\n\nreturn [{\n  json: {\n    ollama_model: body.model || 'copy-max',\n    ollama_temp: temperature,\n    ollama_num_predict: body.num_predict || 800,\n    prompt_payload: JSON.stringify(inputJson, null, 2),\n    request_meta: { platform, persona, framework, language, topic, variants, timestamp: new Date().toISOString() }\n  }\n}];"
      },
      "typeVersion": 2
    },
