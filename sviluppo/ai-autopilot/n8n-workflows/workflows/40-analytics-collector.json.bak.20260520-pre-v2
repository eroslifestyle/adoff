    {
      "parameters": {
        "jsCode": "// Normalize Twitter response\nconst data = $json.data || {};\nconst pm = data.public_metrics || {};\nconst npm = data.non_public_metrics || {};\nconst om = data.organic_metrics || {};\n\nconst likes = pm.like_count || 0;\nconst comments = pm.reply_count || 0;\nconst shares = pm.retweet_count || 0;\nconst views = pm.impression_count || om.impression_count || 0;\nconst impressions = views;\nconst reach = npm.impressions || impressions;\nconst clicks = npm.url_link_clicks || 0;\nconst saves = npm.bookmark_count || pm.bookmark_count || 0;\nconst engagement_rate = impressions > 0 ? ((likes + comments*2 + shares*3 + saves*4) / impressions * 100) : 0;\n\nreturn [{ json: {\n  social_published_id: $('Query posts (14d window)').item.json.id,\n  platform: 'twitter',\n  platform_post_id: $('Query posts (14d window)').item.json.platform_post_id,\n  measured_at: new Date().toISOString(),\n  likes: likes,\n  comments: comments,\n  shares: shares,\n  views: views,\n  impressions: impressions,\n  reach: reach,\n  clicks: clicks,\n  saves: saves,\n  engagement_rate: parseFloat(engagement_rate.toFixed(2)),\n  raw_payload: $json\n}}];"
      },
      "id": "norm_twitter",
      "name": "Normalize Twitter",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        150
      ]
    },
    {
      "parameters": {
        "jsCode": "// Normalize Reddit response\nconst data = $json.data || {};\nconst likes = data.ups || 0;\nconst comments = data.num_comments || 0;\nconst shares = 0; // Reddit doesn't expose share count\nconst views = data.ups + data.downs || likes;\nconst impressions = views * 2; // Rough estimate\nconst reach = impressions;\nconst clicks = 0;\nconst saves = data.saved ? 1 : 0;\nconst engagement_rate = impressions > 0 ? ((likes + comments*2 + shares*3 + saves*4) / impressions * 100) : 0;\n\nreturn [{ json: {\n  social_published_id: $('Query posts (14d window)').item.json.id,\n  platform: 'reddit',\n  platform_post_id: $('Query posts (14d window)').item.json.platform_post_id,\n  measured_at: new Date().toISOString(),\n  likes: likes,\n  comments: comments,\n  shares: shares,\n  views: views,\n  impressions: impressions,\n  reach: reach,\n  clicks: clicks,\n  saves: saves,\n  engagement_rate: parseFloat(engagement_rate.toFixed(2)),\n  raw_payload: $json\n}}];"
      },
      "id": "norm_reddit",
      "name": "Normalize Reddit",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        350
      ]
    },
    {
      "parameters": {
        "jsCode": "// Normalize Mastodon response\nconst likes = $json.favourites_count || 0;\nconst comments = $json.replies_count || 0;\nconst shares = $json.reblogs_count || 0;\nconst views = 0; // Mastodon doesn't expose view count\nconst impressions = 0;\nconst reach = 0;\nconst clicks = 0;\nconst saves = 0; // Mastodon doesn't track this\nconst engagement_rate = (likes + comments + shares) > 0 ? ((likes + comments*2 + shares*3) * 100 / max(likes+comments+shares, 1)) : 0;\n\nreturn [{ json: {\n  social_published_id: $('Query posts (14d window)').item.json.id,\n  platform: 'mastodon',\n  platform_post_id: $('Query posts (14d window)').item.json.platform_post_id,\n  measured_at: new Date().toISOString(),\n  likes: likes,\n  comments: comments,\n  shares: shares,\n  views: views,\n  impressions: impressions,\n  reach: reach,\n  clicks: clicks,\n  saves: saves,\n  engagement_rate: parseFloat(engagement_rate.toFixed(2)),\n  raw_payload: $json\n}}];"
      },
      "id": "norm_mastodon",
      "name": "Normalize Mastodon",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        550
      ]
    },
    {
      "parameters": {
        "jsCode": "// Normalize Bluesky response\nconst record = $json.value || {};\nconst likes = record.likeCount || 0;\nconst comments = record.replyCount || 0;\nconst shares = record.shareCount || 0;\nconst views = 0; // Bluesky doesn't expose view count in direct API\nconst impressions = 0;\nconst reach = 0;\nconst clicks = 0;\nconst saves = 0;\nconst engagement_rate = (likes + comments + shares) > 0 ? ((likes + comments*2 + shares*3) * 100 / max(likes+comments+shares, 1)) : 0;\n\nreturn [{ json: {\n  social_published_id: $('Query posts (14d window)').item.json.id,\n  platform: 'bluesky',\n  platform_post_id: $('Query posts (14d window)').item.json.platform_post_id,\n  measured_at: new Date().toISOString(),\n  likes: likes,\n  comments: comments,\n  shares: shares,\n  views: views,\n  impressions: impressions,\n  reach: reach,\n  clicks: clicks,\n  saves: saves,\n  engagement_rate: parseFloat(engagement_rate.toFixed(2)),\n  raw_payload: $json\n}}];"
      },
      "id": "norm_bluesky",
      "name": "Normalize Bluesky",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
