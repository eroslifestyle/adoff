        "operation": "executeQuery",
        "query": "SELECT id, platform, platform_post_id, published_at FROM adoff_autopilot.social_published WHERE published_at > NOW() - INTERVAL '14 days' AND status='published' ORDER BY id DESC LIMIT 200;",
        "options": {}
