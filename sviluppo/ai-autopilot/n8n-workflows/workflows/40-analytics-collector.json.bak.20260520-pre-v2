    {
      "parameters": {
        "jsCode": "// Validate webhook HMAC signature (from W29 system)\nconst crypto = require('crypto');\nconst signature = $request.headers?.['x-adoff-signature'];\nconst body = $request.body;\nconst secret = process.env.WEBHOOK_SIGNING_SECRET || 'dev-secret';\n\nif (signature && body) {\n  const hmac = crypto.createHmac('sha256', secret)\n    .update(JSON.stringify(body))\n    .digest('hex');\n  if (hmac !== signature) {\n    return [{ json: { error: 'Invalid signature', authenticated: false } }];\n  }\n}\n\nreturn [{ json: { authenticated: true, triggered_at: new Date().toISOString() } }];"
      },
      "id": "auth",
      "name": "Validate HMAC",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        400
      ]
