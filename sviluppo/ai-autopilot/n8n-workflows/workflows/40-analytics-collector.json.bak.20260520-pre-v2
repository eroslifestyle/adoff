    {
      "parameters": {
        "jsCode": "// Check if token is present before storing\nconst platform = $json.platform;\nconst tokenEnvMap = {\n  'twitter': 'TWITTER_BEARER_TOKEN',\n  'reddit': 'REDDIT_OAUTH_TOKEN',\n  'mastodon': 'MASTODON_TOKEN',\n  'bluesky': 'BLUESKY_SESSION_TOKEN'\n};\n\nconst envKey = tokenEnvMap[platform];\nconst tokenExists = process.env[envKey] && process.env[envKey].length > 0;\n\nif (!tokenExists) {\n  return [{ json: {\n    skipped: true,\n    platform: platform,\n    reason: `Missing token: ${envKey}`,\n    message: `Analytics skipped for ${platform}, token not configured`\n  }}];\n}\n\n// Token exists, pass through for insert\nreturn [$json];"
      },
