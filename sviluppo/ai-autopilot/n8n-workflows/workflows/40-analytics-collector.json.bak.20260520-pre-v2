        "jsCode": "// Handle post deleted case (404) - mark as archived\nif ($json.status === 404 || $json.statusCode === 404) {\n  // Signal to update post status\n  return [{ json: {\n    deleted: true,\n    platform_post_id: $('Query posts (14d window)').item.json.platform_post_id,\n    message: 'Post deleted, marking as archived'\n  }}];\n}\n\nreturn [{ json: { deleted: false } }];"
      },
