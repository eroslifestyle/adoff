      "id": "9b3f1a01-1500-4001-9001-000000000006",
      "name": "Copy agent (Ollama)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1180,
        220
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse risposta Ollama + brand-guard + build SQL.\nconst input = $input.first().json;\nlet parsed;\ntry {\n  const txt = (input.response || input.choices?.[0]?.message?.content || '').trim();\n  parsed = JSON.parse(txt);\n} catch (e) {\n  return [{ json: { ok:false, error:'copy parse failed: '+e.message, raw: input } }];\n}\nconst caption = (parsed.caption || '').toString().trim();\n// Normalize hashtags: collapse spaces, remove '# ' → '#', dedupe, ensure leading '#'.\nlet raw = Array.isArray(parsed.hashtags) ? parsed.hashtags : [];\nconst seen = new Set();\nconst hashtags = raw\n  .map(h => String(h||'').trim().replace(/\\s+/g,'').replace(/^#+/,'#'))\n  .map(h => h.startsWith('#') ? h : '#'+h)\n  .filter(h => h.length>1)\n  .filter(h => { const k=h.toLowerCase(); if(seen.has(k))return false; seen.add(k); return true; })\n  .slice(0, 10);\nconst disclosure = (parsed.disclosure || '').toString().trim();\nconst FULL = (caption + ' ' + hashtags.join(' ') + ' ' + disclosure).toLowerCase();\nconst BAN = /(youtube|google|facebook|instagram|tiktok|amazon|reddit|twitch|chrome|firefox|safari|edge|opera|\\b15[ -]?day\\b|\\btrial\\b|\\bpaid\\b|\\bsubscription\\b)/i;\nconst hit = FULL.match(BAN);\nif (hit) return [{ json: { ok:false, error:'brand-guard BLOCK: '+hit[0], caption, hashtags, disclosure } }];\nconst meta = $('Parse build JSON').first().json;\nconst video = meta.build?.render?.file || '';\nconst full = caption + '\\n\\n' + hashtags.join(' ') + '\\n\\n' + disclosure;\nconst q = (s) => \"'\" + String(s).replace(/'/g, \"''\") + \"'\";\nconst sql = `INSERT INTO adoff_autopilot.social_posts (\n  brand, platform, account_ref, media_type, media_path,\n  no_logo_variant, caption, hashtags, lang, privacy_level,\n  allow_comment, allow_duet, allow_stitch, ai_generated, status, created_at\n) VALUES\n  ('adoff','instagram','@adoff.app','video',${q(video)},FALSE,${q(full)},${q(hashtags.join(' '))},${q(meta.lang)},'PUBLIC_TO_EVERYONE',TRUE,FALSE,FALSE,TRUE,'draft',NOW()),\n  ('adoff','facebook' ,'adoff.app' ,'video',${q(video)},FALSE,${q(full)},${q(hashtags.join(' '))},${q(meta.lang)},'PUBLIC_TO_EVERYONE',TRUE,FALSE,FALSE,TRUE,'draft',NOW()),\n  ('adoff','tiktok'   ,'adoff_app' ,'video',${q(video)},TRUE ,${q(full)},${q(hashtags.join(' '))},${q(meta.lang)},'SELF_ONLY'        ,TRUE,FALSE,FALSE,TRUE,'draft',NOW())\nRETURNING id, platform;`;\nreturn [{ json: { ok:true, lang: meta.lang, concept: meta.concept, caption, hashtags, disclosure, video_path: video, full_caption: full, sql } }];"
      },
