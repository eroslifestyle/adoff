      "name": "Set seeds + esplodi",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 300],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const input = items[0]?.json?.body || items[0]?.json || {};\nconst seeds = Array.isArray(input.seeds) && input.seeds.length ? input.seeds : ['ad blocker browser','blocca pubblicità Chrome','rimuovere annunci video','privacy navigazione','estensione blocca pubblicità'];\nconst langs = Array.isArray(input.langs) && input.langs.length ? input.langs : ['it','en'];\nconst market = input.market || 'EU';\nconst out = [];\nfor (const seed of seeds) {\n  for (const lang of langs) {\n    out.push({ json: { seed, lang, market } });\n  }\n}\nreturn out;"
      }
