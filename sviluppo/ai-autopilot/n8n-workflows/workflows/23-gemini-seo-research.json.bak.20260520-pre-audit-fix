    {
      "id": "n23-005-build-prompt",
      "name": "Build SEO prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 300],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const { seed, lang, market } = $json;\nconst LANG_NAMES = { it:'italiano', en:'English', de:'Deutsch', fr:'français', es:'español' };\nconst langName = LANG_NAMES[lang] || lang;\nconst schema = JSON.stringify({\n  main_keyword: 'string',\n  search_intent: 'informational|commercial|transactional|navigational',\n  monthly_volume_estimate: 'low|medium|high',\n  difficulty_estimate: 'low|medium|high',\n  long_tail_variants: ['string'],\n  related_questions: ['string'],\n  topic_cluster: { pillar:'string', supporting_topics:['string'] },\n  content_brief: { h1:'string', proposed_h2s:['string'], key_points:['string'], word_count_target:1200, internal_links_to:['string'] },\n  meta: { title:'string', description:'string', slug:'string' }\n});\nconst prompt = `Sei SEO strategist per AdOff (estensione browser ad blocker). Analizza la seed keyword e produci un brief SEO completo in ${langName}.\\n\\nSEED: \"${seed}\"\\nMARKET: ${market}\\nLANG: ${langName}\\n\\nVINCOLI ASSOLUTI: MAI nominare brand famosi (YouTube, Google, Facebook, Instagram, TikTok, Twitter, X, Amazon, Reddit, Twitch, GitHub, LinkedIn) — usa sinonimi. MAI \"149 KB\"/varianti. Output solo in ${langName}.\\n\\nDELIVERABLE:\\n- main_keyword normalizzata (lowercase, no varianti).\\n- search_intent classificato.\\n- 8-15 long_tail_variants (3-6 parole, naturali, in ${langName}).\\n- 5-10 related_questions (People Also Ask style).\\n- topic_cluster con 1 pillar + 5-8 supporting_topics.\\n- content_brief con H1 punchy, 5-8 H2 logici, 8-12 key_points concreti, word_count_target realistico.\\n- meta.title ≤60 char, meta.description 140-160 char, meta.slug kebab-case.\\n\\nRESTITUISCI SOLO JSON VALIDO (no markdown fences):\\n${schema}`;\nreturn [{ json: { ...$json, prompt, model:'gemini-2.5-flash' } }];"
      }
    },
    {
      "id": "n23-006-http-gemini",
      "name": "Gemini 2.5 Flash",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1200, 300],
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" } ] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ contents:[{role:'user',parts:[{text:$json.prompt}]}], generationConfig:{ temperature:0.6, topP:0.9, maxOutputTokens:2400, responseMimeType:'application/json', thinkingConfig:{thinkingBudget:0} }, safetySettings:[{category:'HARM_CATEGORY_HARASSMENT',threshold:'BLOCK_NONE'},{category:'HARM_CATEGORY_HATE_SPEECH',threshold:'BLOCK_NONE'},{category:'HARM_CATEGORY_SEXUALLY_EXPLICIT',threshold:'BLOCK_NONE'},{category:'HARM_CATEGORY_DANGEROUS_CONTENT',threshold:'BLOCK_NONE'}] }) }}",
