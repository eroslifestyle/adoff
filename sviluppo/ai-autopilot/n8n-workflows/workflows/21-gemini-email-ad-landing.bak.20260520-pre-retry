      "parameters": {
        "language": "javaScript",
        "jsCode": "// F004 cost-cap + F003 sanitize\nconst input = items[0]?.json?.body || items[0]?.json || {};\nconst MAX_ASSETS=3, MAX_LANGS=10, MAX_VARIANTS=5, MAX_CONCEPT=1500;\nlet assets = Array.isArray(input.asset_types) && input.asset_types.length ? input.asset_types : ['email_drip','ad_copy','landing_section'];\nlet langs = Array.isArray(input.langs) && input.langs.length ? input.langs : ['it','en'];\nassets = assets.slice(0,MAX_ASSETS).filter(a=>/^[a-z_]{4,30}$/.test(a));\nlangs = langs.slice(0,MAX_LANGS).filter(l=>/^[a-z]{2,5}$/i.test(l));\nif (!assets.length || !langs.length) throw new Error('Invalid input arrays');\nconst concept = String(input.concept || 'AdOff blocca pubblicità invasiva. Trial 15 giorni Pro gratis.').slice(0,MAX_CONCEPT).replace(/[\\u0000-\\u001f\\u007f]/g,'');\nconst tone = String(input.tone || 'energica, brillante, diretta').slice(0,200);\nconst use_pro = !!input.use_pro;\nconst variantsByType = { email_drip:1, ad_copy:3, landing_section:1 };\nconst contextByType = { email_drip: input.email_context || 'welcome_day_1', ad_copy: input.ad_platform || 'meta-ads', landing_section: input.landing_section || 'hero' };\nconst out = [];\nfor (const asset of assets) {\n  const nVar = Math.min(input.variants ?? variantsByType[asset] ?? 1, MAX_VARIANTS);\n  for (const lang of langs) {\n    for (let v=0; v<nVar; v++) {\n      out.push({ json: { asset_type:asset, lang, concept, tone, use_pro, variant_index:v, ctx:String(contextByType[asset]).slice(0,80) } });\n    }\n  }\n}\nif (out.length > 60) throw new Error('Too many combinations: '+out.length+' > 60');\nreturn out;"
      }
