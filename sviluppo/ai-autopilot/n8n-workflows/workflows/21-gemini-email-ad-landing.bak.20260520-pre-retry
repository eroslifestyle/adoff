      "id": "n21-002-trigger-webhook-hmac-check",
      "name": "HMAC-n21-002-trigger-webhook",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        300
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "// HMAC-SHA256 Webhook Authentication (inline)\n// Validates X-AdOff-Signature header against raw body\n// Returns ok:true + extracted payload, or blocks with 401\n\nconst crypto = require('crypto');\nconst secret = process.env.WEBHOOK_HMAC_SECRET;\n\nif (!secret) {\n  throw new Error('WEBHOOK_HMAC_SECRET not configured');\n}\n\n// Extract signature from headers\nconst signature = $json.$headers?.['x-adoff-signature'] || $json.headers?.['x-adoff-signature'];\nconst body = $json.$body || $json.body || JSON.stringify($json);\n\n// In DEV_MODE (env), skip check\nif (process.env.DEV_MODE === 'true') {\n  return [{ json: { ...($json.body || $json), __hmac_skipped: true } }];\n}\n\nif (!signature) {\n  return [{ json: { __hmac_error: 'missing_signature_header', statusCode: 401 } }];\n}\n\n// Calculate expected HMAC\nlet bodyForHmac = body;\nif (typeof body === 'object') {\n  bodyForHmac = JSON.stringify(body);\n}\n\nconst expectedHmac = crypto\n  .createHmac('sha256', Buffer.from(secret, 'hex'))\n  .update(bodyForHmac, 'utf8')\n  .digest('hex');\n\n// Timing-safe comparison\ntry {\n  crypto.timingSafeEqual(\n    Buffer.from(signature, 'hex'),\n    Buffer.from(expectedHmac, 'hex')\n  );\n  // Valid signature: continue with payload\n  return [{ json: { ...($json.body || $json), __hmac_validated: true } }];\n} catch (err) {\n  return [{ json: { __hmac_error: 'invalid_signature', statusCode: 401 } }];\n}"
      }
