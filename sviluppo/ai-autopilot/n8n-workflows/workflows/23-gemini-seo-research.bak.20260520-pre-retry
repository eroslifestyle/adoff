      "parameters": {
        "language": "javaScript",
        "jsCode": "// F004 cost-cap + F003 sanitize\nconst input = items[0]?.json?.body || items[0]?.json || {};\nconst MAX_SEEDS=20, MAX_LANGS=10, MAX_SEED_LEN=120;\nconst seeds0 = Array.isArray(input.seeds) && input.seeds.length ? input.seeds : ['ad blocker browser','blocca pubblicità Chrome','rimuovere annunci video','privacy navigazione','estensione blocca pubblicità'];\nlet seeds = seeds0.slice(0,MAX_SEEDS).map(s=>String(s).slice(0,MAX_SEED_LEN).replace(/[\\u0000-\\u001f\\u007f]/g,'')).filter(Boolean);\nlet langs = (Array.isArray(input.langs) && input.langs.length ? input.langs : ['it','en']).slice(0,MAX_LANGS).filter(l=>/^[a-z]{2,5}$/i.test(l));\nif (!seeds.length || !langs.length) throw new Error('Invalid seeds or langs');\nconst market = String(input.market || 'EU').slice(0,40);\nconst out = [];\nfor (const seed of seeds) for (const lang of langs) out.push({ json: { seed, lang, market } });\nif (out.length > 50) throw new Error('Too many combinations: '+out.length+' > 50');\nreturn out;"
