        400
      ],
      "credentials": {
        "postgres": {
          "id": "PLACEHOLDER_PG_CREDENTIAL",
          "name": "n8n-postgres"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Load token from oauth_tokens table for this platform\nconst platform = $json.platform;\nconst tokenQuery = await $nodeExecute('Postgres', 'executeQuery', {\n  query: `SELECT access_token FROM adoff_autopilot.oauth_tokens WHERE platform=$1 AND status='active' LIMIT 1`,\n  options: { queryReplacement: `'${platform}'` }\n});\n\nconst token = tokenQuery[0]?.json?.access_token || null;\nif (!token) {\n  return [{ json: {\n    skipped: true,\n    platform: platform,\n    reason: `Token not found or expired in oauth_tokens table`,\n    message: `Analytics skipped for ${platform}, token not configured`\n  }}];\n}\n\nreturn [{ json: {\n  ...($json || {}),\n  oauth_token: token,\n  token_ready: true\n}}];"
      },
