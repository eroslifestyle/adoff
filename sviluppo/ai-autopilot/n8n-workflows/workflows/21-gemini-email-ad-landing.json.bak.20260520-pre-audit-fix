    {
      "id": "n21-003-set-defaults",
      "name": "Set defaults + esplodi",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 300],
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Esplodi su (asset_type × lang × variant_index)\nconst input = items[0]?.json?.body || items[0]?.json || {};\nconst assets = Array.isArray(input.asset_types) && input.asset_types.length ? input.asset_types : ['email_drip','ad_copy','landing_section'];\nconst langs = Array.isArray(input.langs) && input.langs.length ? input.langs : ['it','en'];\nconst concept = input.concept || 'AdOff blocca la pubblicità invasiva: video puliti, navigazione veloce, privacy. Trial 15 giorni Pro gratis.';\nconst tone = input.tone || 'energica, brillante, diretta';\nconst use_pro = !!input.use_pro;\nconst variantsByType = { email_drip:1, ad_copy:3, landing_section:1 };\nconst contextByType = { email_drip: input.email_context || 'welcome_day_1', ad_copy: input.ad_platform || 'meta-ads', landing_section: input.landing_section || 'hero' };\nconst out = [];\nfor (const asset of assets) {\n  const nVar = input.variants ?? variantsByType[asset] ?? 1;\n  for (const lang of langs) {\n    for (let v=0; v<nVar; v++) {\n      out.push({ json: { asset_type:asset, lang, concept, tone, use_pro, variant_index:v, ctx:contextByType[asset] } });\n    }\n  }\n}\nreturn out;"
      }
    },
    {
      "id": "n21-004-split-batches",
      "name": "Throttle",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [720, 300],
      "parameters": { "batchSize": 1, "options": {} }
