      "id": "n22-006-parse-guard",
      "name": "Parse + Brand-guard",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        300
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "\nfunction normalizeForGuard(s) {\n  if (!s) return '';\n  return String(s)\n    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')\n    .toLowerCase()\n    .replace(/[\u00b7\u2022\u200b-\u200d\ufeff\u2060]/g, '')\n    .replace(/\\s+/g, ' ');\n}\nfunction brandGuardCheck(rawText) {\n  const t = normalizeForGuard(rawText);\n  const BRANDS = ['youtube','you tube','y-tube','y tube','google','g00gle','g\u043e\u043egle','facebook','face book','instagram','insta gram','tiktok','tik tok','tik-tok','twitter','\\bx\\b','amazon','reddit','twitch','github','linkedin','chrome','firefox','safari','microsoft edge','opera'];\n  for (const b of BRANDS) {\n    const rx = new RegExp(b.replace(/\\\\b/g,'(?:^|[^\\\\p{L}\\\\p{N}])').replace(/\\\\s+/g,'\\\\s*'),'iu');\n    if (rx.test(t)) return { ok:false, hit:b };\n  }\n  const SIZE = /149[\\s\\-_]*k(?:ilo)?b(?:yte)?s?/iu;\n  if (SIZE.test(t)) return { ok:false, hit:'149kb' };\n  const BANNED_TERMS = /\\b(15[\\s\\-]?day|trial|paid plan|subscription|sottoscrizione|abbonamento|pricing|euro\\/mese)/iu;\n  if (BANNED_TERMS.test(t)) return { ok:false, hit:'pricing_term' };\n  return { ok:true };\n}\n\nconst meta = $('Build strategist prompt').item.json;\nconst resp = $json;\nlet text=''; try { text = resp.candidates?.[0]?.content?.parts?.[0]?.text || ''; } catch(e){}\nlet parsed=null;\ntry { parsed = JSON.parse(text); } catch(e) { const m=text.match(/\\{[\\s\\S]*\\}/); if(m){ try{parsed=JSON.parse(m[0]);}catch(e2){} } }\nif (!parsed || !parsed.executive_summary) return [{ json: { ...meta, ok:false, reason:'gemini_no_valid_json', raw:text.slice(0,400) } }];\nconst full = JSON.stringify(parsed);\nconst guard = brandGuardCheck(full);\nif (!guard.ok) return [{ json: { ...meta, ok:false, reason:'brand_guard_'+guard.hit, preview:full.slice(0,300) } }];\nreturn [{ json: { ...meta, ok:true, body_json: full, tokens_in: resp.usageMetadata?.promptTokenCount||0, tokens_out: resp.usageMetadata?.candidatesTokenCount||0, calendar_size:(parsed.calendar||[]).length, n_personas:(parsed.target_personas||[]).length, n_channels:(parsed.channels||[]).length } }];"
      }
