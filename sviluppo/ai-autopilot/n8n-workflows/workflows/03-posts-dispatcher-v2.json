      "id": "post-http",
      "name": "POST to social API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3280,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const resp = $input.first().json || {};\nconst post = $('loop-posts').item.json;\nconst api = $('build-platform-body').item.json.api_config;\nlet success = false, post_id = '', error = '';\n\ntry {\n  if (!resp.error && !resp.errors) {\n    if (resp.data?.id) post_id = resp.data.id;\n    else if (resp.id) post_id = resp.id;\n    else if (resp.json?.data?.id) post_id = resp.json.data.id;\n    success = !!post_id;\n  } else {\n    error = (resp.error || resp.errors?.[0]?.message || JSON.stringify(resp)).slice(0, 300);\n  }\n} catch(e) {\n  error = e.message;\n}\n\nreturn [{json: { post_id: post.id, platform: post.platform, success, platform_post_id: post_id, error, response_status: resp.status || 'unknown' }}];"
      },
