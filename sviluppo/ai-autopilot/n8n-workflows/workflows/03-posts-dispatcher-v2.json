    {
      "parameters": {
        "jsCode": "const ch = $input.first().json[0];\nconst post = $('loop-posts').item.json;\nconst now = new Date();\nconst [start, end] = (ch.posting_window || '00:00-23:59').split('-').map(t => parseInt(t.replace(':','')));\nconst curr = now.getHours() * 100 + now.getMinutes();\nconst in_window = curr >= start && curr < end;\nreturn [{json: { in_window, curr_hour_minute: curr, window: ch.posting_window, platform: post.platform, post_id: post.id }}];"
      },
      "id": "check-posting-window",
      "name": "Check posting_window",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1780,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2
          },
          "conditions": [
            {
              "leftValue": "={{ $json.in_window }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ]
        }
      },
      "id": "if-out-window",
      "name": "Out of window?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        2000,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const post = $('loop-posts').item.json;\nconst ch = $('fetch-channel').item.json[0];\nconst [start_str] = (ch.posting_window || '00:00-23:59').split('-');\nconst [h, m] = start_str.split(':').map(Number);\nconst now = new Date();\nconst next_slot = new Date(now);\nif (now.getHours() * 100 + now.getMinutes() >= h * 100 + m) {\n  next_slot.setDate(next_slot.getDate() + 1);\n}\nnext_slot.setHours(h, m, 0, 0);\nconst scheduled_ts = Math.floor(next_slot.getTime() / 1000);\nreturn [{json: { post_id: post.id, scheduled_at_ts: scheduled_ts, action: 'requeue_next_window' }}];"
      },
      "id": "calc-next-window",
      "name": "Calculate next_window slot",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2200,
        200
      ]
    },
