    {
      "parameters": {
        "jsCode": "const post = $('loop-posts').item.json;\nconst ch = $('fetch-channel').item.json[0];\nconst plt = post.platform.toLowerCase();\nconst body = post.body || '';\nconst token_ref = ch.oauth_token_ref || '';\n\nlet api_config = { endpoint: '', method: 'POST', headers: {}, body_obj: {} };\n\nswitch(plt) {\n  case 'twitter':\n    api_config.endpoint = 'https://api.twitter.com/2/tweets';\n    api_config.headers = { 'Authorization': `Bearer ${token_ref}`, 'Content-Type': 'application/json' };\n    api_config.body_obj = { text: body.slice(0, 280) };\n    break;\n  case 'mastodon':\n    api_config.endpoint = (ch.api_endpoint || 'https://fosstodon.org') + '/api/v1/statuses';\n    api_config.headers = { 'Authorization': `Bearer ${token_ref}`, 'Content-Type': 'application/json' };\n    api_config.body_obj = { status: body.slice(0, 500), visibility: 'public' };\n    break;\n  case 'reddit':\n    api_config.endpoint = 'https://oauth.reddit.com/api/submit';\n    api_config.headers = { 'Authorization': `Bearer ${token_ref}`, 'Content-Type': 'application/x-www-form-urlencoded', 'User-Agent': 'AdOffBot/1.0' };\n    api_config.body_form = { api_type: 'json', kind: 'self', sr: (post.body || '').match(/\\/r\\/([\\w-]+)/)?.[1] || 'test', title: body.split('\\\\n')[0].slice(0, 300), text: body };\n    api_config.use_form = true;\n    break;\n  case 'instagram':\n    api_config.endpoint = `https://graph.facebook.com/v18.0/${ch.api_endpoint || 'IG_ID'}/media`;\n    api_config.headers = { 'Content-Type': 'application/json' };\n    api_config.body_obj = { image_url: 'PLACEHOLDER', caption: body.slice(0, 2200) };\n    api_config.placeholder = true;\n    break;\n  case 'facebook':\n    api_config.endpoint = `https://graph.facebook.com/v18.0/${ch.api_endpoint || 'PAGE_ID'}/feed`;\n    api_config.headers = { 'Content-Type': 'application/json' };\n    api_config.body_obj = { message: body.slice(0, 63206), access_token: token_ref };\n    break;\n  case 'tiktok':\n    api_config.endpoint = 'https://open.tiktokapis.com/v2/post/publish/inbox/video/init/';\n    api_config.headers = { 'Authorization': `Bearer ${token_ref}`, 'Content-Type': 'application/json' };\n    api_config.body_obj = { source_info: { source: 'PULL_FROM_URL', video_url: 'PLACEHOLDER' }, post_info: { desc: body.slice(0, 2200) } };\n    api_config.placeholder = true;\n    break;\n  case 'linkedin':\n    api_config.endpoint = 'https://api.linkedin.com/v2/ugcPosts';\n    api_config.headers = { 'Authorization': `Bearer ${token_ref}`, 'Content-Type': 'application/json', 'LinkedIn-Version': '202304' };\n    api_config.body_obj = { author: 'PLACEHOLDER_URN', lifecycleState: 'PUBLISHED', specificContent: { 'com.linkedin.ugc.UGCPost': { content: { media: [], title: { text: body.slice(0, 200) }, description: { text: body.slice(0, 3000) } } } }, visibility: { 'com.linkedin.ugc.MemberNetworkVisibility': 'PUBLIC' } };\n    api_config.placeholder = true;\n    break;\n  case 'bluesky':\n    api_config.endpoint = 'https://bsky.social/xrpc/com.atproto.repo.createRecord';\n    api_config.headers = { 'Authorization': `Bearer ${token_ref}`, 'Content-Type': 'application/json' };\n    api_config.body_obj = { repo: process.env.BLUESKY_DID || 'DID_NOT_SET', collection: 'app.bsky.feed.post', record: { text: body.slice(0, 300), createdAt: new Date().toISOString() } };\n    api_config.placeholder = true;\n    break;\n  default:\n    api_config.endpoint = 'https://api.example.com/unknown';\n    api_config.error = `Unknown platform: ${plt}`;\n}\n\nreturn [{json: { api_config, post_id: post.id, platform: plt, has_token: !!token_ref, placeholder: api_config.placeholder || false }}];"
      },
      "id": "build-platform-body",
      "name": "Build platform-specific body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
