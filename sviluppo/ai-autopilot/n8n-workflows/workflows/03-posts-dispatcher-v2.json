        "headers": "={{ JSON.stringify($json.api_config.headers) }}",
        "sendBody": true,
        "specifyBody": "={{ $json.api_config.use_form ? 'form' : 'json' }}",
        "jsonBody": "={{ !$json.api_config.use_form ? JSON.stringify($json.api_config.body_obj) : '{}' }}",
        "bodyParameters": "={{ $json.api_config.use_form ? Object.entries($json.api_config.body_form || {}).map(([k,v]) => ({name:k,value:v})) : [] }}",
        "options": {
          "timeout": 30000,
          "response": {
            "response": {
              "neverError": true
            }
